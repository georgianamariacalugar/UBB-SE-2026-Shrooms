<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="MovieShop.Views.WalletView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls">

    <Grid Padding="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- TOP: Title + Balance -->
        <Grid Grid.Row="0" Margin="20,0,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="My Wallet"
                       FontSize="28"
                       FontWeight="Bold"
                       Margin="0,0,0,0"
                       VerticalAlignment="Center"/>

            <!-- Balance top right -->
            <StackPanel Grid.Column="1"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Padding="16,8">
                <TextBlock Text="Current Balance"
                           FontSize="12"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="{x:Bind ViewModel.DisplayBalance, Mode=OneWay}"
                           FontSize="28"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- Feedback Messages -->
        <StackPanel Grid.Row="1" Margin="0,0,0,10">
            <TextBlock Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                       Foreground="Red"
                       FontSize="14"/>
            <TextBlock Text="{x:Bind ViewModel.SuccessMessage, Mode=OneWay}"
                       Foreground="Green"
                       FontSize="14"/>
        </StackPanel>

        <!-- Top Up Form -->
        <Border Grid.Row="2"
                CornerRadius="8"
                Padding="20"
                Margin="0,0,0,20">
            <StackPanel Spacing="12">
                <TextBlock Text="Add Funds"
                           FontSize="18"
                           FontWeight="SemiBold"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Cardholder Name -->
                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,10,10">
                        <TextBlock Text="Cardholder Name" FontSize="12" Margin="0,0,0,4"/>
                        <TextBox PlaceholderText="John Doe"
                                 Text="{x:Bind ViewModel.CardHolderName, Mode=TwoWay}"/>
                    </StackPanel>

                    <!-- Amount -->
                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="10,0,0,10">
                        <TextBlock Text="Amount" FontSize="12" Margin="0,0,0,4"/>
                        <NumberBox PlaceholderText="0.00"
                                   Value="{x:Bind ViewModel.TopUpAmount, Mode=TwoWay}"
                                   Minimum="0"
                                   SpinButtonPlacementMode="Inline"/>
                    </StackPanel>

                    <!-- Card Number -->
                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,10,10">
                        <TextBlock Text="Card Number" FontSize="12" Margin="0,0,0,4"/>
                        <TextBox PlaceholderText="1234567890123456"
                             Text="{x:Bind ViewModel.CardNumber, Mode=TwoWay}"
                            MaxLength="16"
                            InputScope="Number"/>
                    </StackPanel>

                    <!-- Expiry + CVV -->
                    <Grid Grid.Row="1" Grid.Column="1" Margin="10,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,5,0">
                            <TextBlock Text="Expiry (MM/YY)" FontSize="12" Margin="0,0,0,4"/>
                            <TextBox PlaceholderText="MM/YY"
                                     Text="{x:Bind ViewModel.ExpirationDate, Mode=TwoWay}"
                                     MaxLength="5"
                                     InputScope="Number"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="5,0,0,0">
                            <TextBlock Text="CVV" FontSize="12" Margin="0,0,0,4"/>
                            <TextBox PlaceholderText="123"
                                     Text="{x:Bind ViewModel.CVV, Mode=TwoWay}"
                                     MaxLength="3"
                                     InputScope="Number"/>
                        </StackPanel>
                    </Grid>

                    <!-- Add Funds Button -->
                    <Button Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                            Content="Add Funds"
                            Command="{x:Bind ViewModel.TopUpCommand}"
                            HorizontalAlignment="Stretch"
                            FontSize="16"
                            Padding="0,12"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Transaction History -->
        <Grid Grid.Row="3">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="Transaction History"
                       FontSize="18"
                       FontWeight="SemiBold"
                       Margin="0,0,0,10"/>

            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Auto">

                <controls:DataGrid x:Name="TransactionDataGrid"
                                   ItemsSource="{x:Bind ViewModel.Transactions, Mode=OneWay}"
                                   AutoGenerateColumns="False"
                                   IsReadOnly="True"
                                   GridLinesVisibility="Horizontal"
                                   HorizontalAlignment="Stretch"
                                   CanUserSortColumns="True"
                                   CanUserResizeColumns="True">

                    <controls:DataGrid.Columns>
                        <controls:DataGridTextColumn Header="Date"
                                                     Binding="{Binding DisplayTimestamp}"
                                                     Width="160"/>
                        <controls:DataGridTextColumn Header="Type"
                                                     Binding="{Binding DisplayType}"
                                                     Width="180"/>
                        <controls:DataGridTextColumn Header="Status"
                                                     Binding="{Binding DisplayStatus}"
                                                     Width="140"/>
                        <controls:DataGridTextColumn Header="Amount"
                                                     Binding="{Binding DisplayAmount}"
                                                     Width="120"/>
                    </controls:DataGrid.Columns>
                </controls:DataGrid>
            </ScrollViewer>
        </Grid>

    </Grid>
</Page>
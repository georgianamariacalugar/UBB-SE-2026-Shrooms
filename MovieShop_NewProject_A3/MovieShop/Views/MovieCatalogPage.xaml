<Page
    x:Class="MovieShop.Views.MovieCatalogPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:MovieShop.Models"
    xmlns:local="using:MovieShop.Views"
    mc:Ignorable="d">

    <Page.Resources>
        <local:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Page.Resources>

    <Grid Background="#1E1E1E" Padding="12,8,12,12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Spacing="14" Margin="0,0,16,0">
            <TextBlock Text="Search by title" FontSize="14" Foreground="Gray"/>
            <TextBox x:Name="SearchBox" PlaceholderText="Search..."/>

            <TextBlock Text="Sort" FontSize="18" FontWeight="Bold" Margin="0,8,0,4"/>
            <StackPanel Spacing="6">
                <RadioButton x:Name="SortAscPrice" Content="Ascending price" GroupName="Sort" Checked="SortOption_Changed"/>
                <RadioButton x:Name="SortDescPrice" Content="Descending price" GroupName="Sort" Checked="SortOption_Changed"/>
                <RadioButton x:Name="SortHighRating" Content="Highest rating" GroupName="Sort" Checked="SortOption_Changed"/>
                <RadioButton x:Name="SortLowRating" Content="Lowest rating" GroupName="Sort" Checked="SortOption_Changed"/>
            </StackPanel>
        </StackPanel>

        <Grid Grid.Column="1">
            <TextBlock x:Name="FlashSaleEndedText"
                       Text="The flash sale has ended!"
                       Foreground="White"
                       FontSize="28"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Visibility="Collapsed"/>

            <GridView x:Name="MoviesGrid"
                      SelectionMode="None"
                      IsItemClickEnabled="True"
                      ItemClick="MoviesGrid_ItemClick"
                      Padding="0">
                <GridView.ItemContainerStyle>
                    <Style TargetType="GridViewItem">
                        <Setter Property="Margin" Value="8"/>
                        <Setter Property="Padding" Value="0"/>
                    </Style>
                </GridView.ItemContainerStyle>
                <GridView.ItemTemplate>
                    <DataTemplate x:DataType="local:MovieCatalogItem">
                        <Border Background="#2A2A2A"
                                CornerRadius="10"
                                Padding="0"
                                Width="200"
                                BorderBrush="#404040"
                                BorderThickness="1"
                                RenderTransformOrigin="0.5,0.5"
                                PointerEntered="MovieCard_PointerEntered"
                                PointerExited="MovieCard_PointerExited">
                            <StackPanel Spacing="8" Padding="10">

                                <Grid Height="260">
                                    <Border Background="#1A1A1A" CornerRadius="6">
                                        <Image Source="{x:Bind ImageUrl}" Stretch="UniformToFill"/>
                                    </Border>

                                    <Border Background="#CC5555" CornerRadius="12" Padding="8,4"
                                            HorizontalAlignment="Left" VerticalAlignment="Top"
                                            Margin="10,10,0,0"
                                            Visibility="{x:Bind SaleVisibility, Mode=OneWay}">
                                        <TextBlock Text="SALE" FontSize="12" FontWeight="Bold" Foreground="White"/>
                                    </Border>
                                </Grid>

                                <TextBlock Text="{x:Bind Title}" Foreground="White" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" MaxLines="2" TextWrapping="Wrap"/>

                                <TextBlock Text="{x:Bind RatingAndReviewCountText, Mode=OneWay}"
                                           Foreground="#FFC107"
                                           FontWeight="SemiBold"
                                           TextWrapping="Wrap"/>

                                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">

                                    <TextBlock Text="{x:Bind OriginalPriceText, Mode=OneWay}" 
                                               Foreground="Gray" 
                                               FontSize="14" 
                                               TextDecorations="Strikethrough"
                                               VerticalAlignment="Center"
                                               Visibility="{x:Bind SaleVisibility, Mode=OneWay}"/>

                                    <TextBlock Text="{x:Bind CurrentPriceText, Mode=OneWay}" 
                   Foreground="{x:Bind PriceColor, Mode=OneWay}" 
                   FontSize="16" 
                   FontWeight="Bold"
                   VerticalAlignment="Center"/>

                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </GridView.ItemTemplate>
            </GridView>
        </Grid>
    </Grid>
</Page>

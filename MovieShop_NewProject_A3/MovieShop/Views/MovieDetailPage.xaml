<Page
    x:Class="MovieShop.Views.MovieDetailPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="#1E1E1E">
        <Grid Padding="32">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Button x:Name="BackButton"
                    Grid.Row="0"
                    Content=""
                    FontFamily="Segoe MDL2 Assets"
                    FontSize="24"
                    Click="BackButton_Click"
                    Background="Transparent"
                    Foreground="White"
                    HorizontalAlignment="Left"
                    Margin="0,0,0,16"/>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="#1A1A1A"
                        CornerRadius="12"
                        Margin="0,0,24,0"
                        BorderBrush="#333"
                        BorderThickness="1"
                        MaxHeight="640">
                    <Image x:Name="PosterImage"
                           Stretch="Uniform"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Margin="16"/>
                </Border>

                <StackPanel Grid.Column="1"
                            VerticalAlignment="Center"
                            Spacing="14"
                            MaxWidth="520">

                    <TextBlock x:Name="TitleBlock"
                               FontSize="36"
                               FontWeight="Bold"
                               Foreground="White"
                               TextWrapping="Wrap"/>

                    <TextBlock x:Name="DescriptionBlock"
                               FontSize="16"
                               Foreground="#CCCCCC"
                               TextWrapping="Wrap"/>

                    <TextBlock x:Name="RatingBlock"
                               FontSize="18"
                               Foreground="#FFC107"/>

                    <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center" Margin="0,0,0,16">

                        <TextBlock x:Name="OriginalPriceBlock"
                                           Foreground="Gray"
                                           FontSize="20"
                                           TextDecorations="Strikethrough"
                                           VerticalAlignment="Bottom"
                                           Margin="0,0,0,3"
                                           Visibility="Collapsed"/>

                        <TextBlock x:Name="PriceBlock"
                                        FontSize="28"
                                        Foreground="#1DB954"
                                        FontWeight="Bold"
                                        TextWrapping="Wrap"/>

                    </StackPanel>

                    <Button x:Name="BuyMovieButton"
                            Content="Buy movie"
                            Click="BuyMovieButton_Click"
                            HorizontalAlignment="Stretch"
                            MinHeight="48"
                            CornerRadius="8"
                            FontSize="16"
                            FontWeight="SemiBold"/>

                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button x:Name="ReviewsButton"
                                Grid.Column="0"
                                Content="See reviews"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                MinHeight="44"
                                CornerRadius="8"
                                Click="ReviewsButton_Click"/>
                        <Button x:Name="EventsButton"
                                Grid.Column="1"
                                Content="See related upcoming events"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                MinHeight="44"
                                CornerRadius="8"
                                Click="EventsButton_Click"/>
                    </Grid>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Page>

<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="MovieShop.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:MovieShop.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="#1E1E1E">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border x:Name="BigSaleBanner" 
            Grid.Row="0"
            Padding="10"
            Background="#D32F2F"
            HorizontalAlignment="Stretch" 
            Visibility="{x:Bind FlashSaleVM.BannerVisibility, Mode=OneWay}">

            <StackPanel Spacing="5" HorizontalAlignment="Center">
                <TextBlock Text="{x:Bind FlashSaleVM.DisplayText}"
                           FontWeight="Bold"
                           FontSize="30" 
                           Foreground="White" 
                           HorizontalAlignment="Center"/>

                <TextBlock x:Name="BigTimerText" 
                           Text="{x:Bind FlashSaleVM.TimerText, Mode=OneWay}" FontSize="30" 
                           Foreground="White" 
                           HorizontalAlignment="Center" 
                           FontWeight="Bold"/>

                <Button x:Name="DiscoverButton" 
                    Content="Discover our discounted movies!" 
                    Click="DiscoverButton_Click"
                    HorizontalAlignment="Center" 
                    Background="#B71C1C" 
                    Foreground="White"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Sidebar: search + sort -->
            <StackPanel Grid.Column="0" Spacing="14" Margin="0,0,16,0">
                <TextBlock Text="Search by title" FontSize="14" Foreground="Gray"/>
                <TextBox x:Name="SearchBox" PlaceholderText="Search..."/>

                <TextBlock Text="Sort" FontSize="18" FontWeight="Bold" Margin="0,8,0,4"/>
                <StackPanel Spacing="6">
                    <RadioButton x:Name="SortAscPrice" Content="Ascending price" GroupName="Sort" Checked="SortOption_Changed"/>
                    <RadioButton x:Name="SortDescPrice" Content="Descending price" GroupName="Sort" Checked="SortOption_Changed"/>
                    <RadioButton x:Name="SortHighRating" Content="Highest rating" GroupName="Sort" Checked="SortOption_Changed"/>
                    <RadioButton x:Name="SortLowRating" Content="Lowest rating" GroupName="Sort" Checked="SortOption_Changed"/>
                </StackPanel>
            </StackPanel>

            <!-- Undiscounted movies grid -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="(Movies that are not on sale)"
                           Foreground="Gray"
                           Margin="0,0,0,10"/>

                <GridView x:Name="UndiscountedMoviesGrid"
                          Grid.Row="1"
                          SelectionMode="None"
                          IsItemClickEnabled="True"
                          ItemClick="UndiscountedMoviesGrid_ItemClick"
                          Padding="0">
                    <GridView.ItemContainerStyle>
                        <Style TargetType="GridViewItem">
                            <Setter Property="Margin" Value="8"/>
                            <Setter Property="Padding" Value="0"/>
                        </Style>
                    </GridView.ItemContainerStyle>

                    <GridView.ItemTemplate>
                        <DataTemplate x:DataType="local:MovieCatalogItem">
                            <Border Background="#2A2A2A"
                                    CornerRadius="10"
                                    Padding="0"
                                    Width="200"
                                    BorderBrush="#404040"
                                    BorderThickness="1"
                                    RenderTransformOrigin="0.5,0.5"
                                    PointerEntered="MovieCard_PointerEntered"
                                    PointerExited="MovieCard_PointerExited">
                                <StackPanel Spacing="8" Padding="10">
                                    <Border Height="260" Background="#1A1A1A" CornerRadius="6">
                                        <Image Source="{x:Bind ImageUrl}" Stretch="UniformToFill"/>
                                    </Border>
                                    <TextBlock Text="{x:Bind Title}" Foreground="White" FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis" MaxLines="2" TextWrapping="Wrap"/>
                                    <TextBlock Text="{x:Bind RatingAndReviewCountText, Mode=OneWay}"
                                               Foreground="#FFC107"
                                               FontWeight="SemiBold"
                                               TextWrapping="Wrap"/>
                                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" Spacing="2">
                                            <TextBlock Text="$" Foreground="#1DB954" FontWeight="Bold"/>
                                            <TextBlock Text="{x:Bind OriginalPriceText, Mode=OneWay}" Foreground="#1DB954" FontWeight="Bold"/>
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </GridView.ItemTemplate>
                </GridView>
            </Grid>
        </Grid>
    </Grid>
</UserControl>

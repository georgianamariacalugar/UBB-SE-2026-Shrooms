<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="MovieShop.Views.NavigationPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="using:MovieShop.Views"
    xmlns:viewmodels="using:MovieShop.ViewModels">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top Navigation Bar -->
        <Grid Grid.Row="0" Background="#FF1F1F1F" Padding="10,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- App Title LEFT -->
            <TextBlock Grid.Column="0"
                       Text="🎬 MovieShop"
                       FontSize="18"
                       FontWeight="Bold"
                       Foreground="White"
                       VerticalAlignment="Center"
                       Margin="0,0,20,0"/>

            <!-- Nav Buttons + Balance RIGHT -->
            <StackPanel Grid.Column="2"
                        Orientation="Horizontal"
                        Spacing="5"
                        VerticalAlignment="Center">

                <Button Content="🎥 Shop"
                        Command="{x:Bind ViewModel.NavigateToShopCommand}"
                        Background="Transparent"
                        Foreground="White"
                        BorderThickness="0"
                        Padding="12,8"
                        />

                <Button Content="🛒 Marketplace"
                        Command="{x:Bind ViewModel.NavigateToMarketplaceCommand}"
                        Background="Transparent"
                        Foreground="White"
                        BorderThickness="0"
                        Padding="12,8"/>

                <Button Content="🎫 Tickets"
                        Command="{x:Bind ViewModel.NavigateToTicketsCommand}"
                        Background="Transparent"
                        Foreground="White"
                        BorderThickness="0"
                        Padding="12,8"/>

                <Button Content="🎒 Inventory"
                        Command="{x:Bind ViewModel.NavigateToInventoryCommand}"
                        Background="Transparent"
                        Foreground="White"
                        BorderThickness="0"
                        Padding="12,8"/>

                <Button Content="💳 Wallet"
                        Command="{x:Bind ViewModel.NavigateToWalletCommand}"
                        Background="Transparent"
                        Foreground="White"
                        BorderThickness="0"
                        Padding="12,8"/>

                <!-- Separator -->
                <TextBlock Text="|"
                           Foreground="Gray"
                           VerticalAlignment="Center"
                           Margin="5,0"/>

                <!-- Balance -->
                <TextBlock Text="Balance:"
                     Foreground="Gray"
                    VerticalAlignment="Center"
                    FontSize="13"/>
                <TextBlock Text="{x:Bind ViewModel.Balance, Mode=OneWay}"
                    Foreground="#FF1DB954"
                    FontWeight="Bold"
                    VerticalAlignment="Center"
                    FontSize="15"
                    Margin="4,0,0,0"/>
            </StackPanel>
        </Grid>

        <!-- Page Content -->
        <ContentControl x:Name="ContentArea"
                        Grid.Row="1"
                        HorizontalContentAlignment="Stretch"
                        VerticalContentAlignment="Stretch"/>
    </Grid>
</Page>
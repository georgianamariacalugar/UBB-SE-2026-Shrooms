<Page
    x:Class="MovieShop.Views.StartPageEquipment"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="#1E1E1E">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="30">

            <TextBlock Text="Equipment Marketplace" 
                       FontSize="42" 
                       FontWeight="Bold" 
                       Foreground="White"
                       HorizontalAlignment="Center"/>

            <StackPanel Orientation="Horizontal" Spacing="40" HorizontalAlignment="Center">
                <Button x:Name="BuyButton" 
                        Click="BuyEquipment_Click" 
                        Width="280" Height="180" 
                        CornerRadius="15"
                        Background="DarkGreen" 
                        Foreground="White">
                    <StackPanel Spacing="10">
                        <FontIcon Glyph="&#xE7BF;" FontSize="40"/>
                        <TextBlock Text="BUY EQUIPMENT" FontSize="20" FontWeight="SemiBold"/>
                    </StackPanel>
                </Button>

                <Button x:Name="SellButton" 
                        Click="SellEquipment_Click" 
                        Width="280" Height="180" 
                        CornerRadius="15"
                        Background="DarkBlue" 
                        Foreground="White">
                    <StackPanel Spacing="10">
                        <FontIcon Glyph="&#xECC8;" FontSize="40"/>
                        <TextBlock Text="SELL EQUIPMENT" FontSize="20" FontWeight="SemiBold"/>
                    </StackPanel>
                </Button>
            </StackPanel>

            <TextBlock x:Name="LoginWarningText" 
                       Text="You must be logged in to access the marketplace." 
                       Foreground="#FF5252" 
                       Visibility="Collapsed" 
                       FontSize="16"
                       HorizontalAlignment="Center"/>
        </StackPanel>
    </Grid>
</Page>
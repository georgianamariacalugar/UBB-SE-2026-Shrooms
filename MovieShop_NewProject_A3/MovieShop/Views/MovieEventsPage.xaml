<Page
    x:Class="MovieShop.Views.MovieEventsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:MovieShop.Models"
    mc:Ignorable="d">

    <Grid Background="#1E1E1E" Padding="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="14" Margin="0,0,0,16">
            <Button Content=""
                    FontFamily="Segoe MDL2 Assets"
                    FontSize="24"
                    Click="BackButton_Click"
                    Background="Transparent"
                    Foreground="White"/>
            <TextBlock x:Name="TitleBlock"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="White"
                       VerticalAlignment="Center"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="0,0,0,12">
                <TextBox x:Name="SearchBox" PlaceholderText="Search events..." Width="300" TextChanged="SearchBox_TextChanged"/>
                <ComboBox x:Name="FilterCombo" Width="160" SelectionChanged="FilterCombo_SelectionChanged">
                    <ComboBoxItem Content="All" IsSelected="True"/>
                    <ComboBoxItem Content="Upcoming"/>
                    <ComboBoxItem Content="Past"/>
                </ComboBox>
            </StackPanel>

            <ListView Grid.Row="1" x:Name="EventsList" SelectionMode="None">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:MovieEvent">
                        <Border Background="#252525" CornerRadius="10" BorderBrush="#333" BorderThickness="1" Padding="14" Margin="0,0,0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Background="#1A1A1A" CornerRadius="8" Height="150" Width="110">
                                    <Image Source="{x:Bind PosterUrl}" Stretch="UniformToFill"/>
                                </Border>

                                <StackPanel Grid.Column="1" Spacing="8" Margin="14,0,0,0">
                                    <TextBlock Text="{x:Bind Title}" Foreground="White" FontSize="18" FontWeight="Bold" TextWrapping="Wrap"/>
                                    <TextBlock Text="{x:Bind Description}" Foreground="#CCCCCC" TextWrapping="Wrap"/>
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <TextBlock Text="{x:Bind DisplayDate}" Foreground="Gray"/>
                                        <TextBlock Text="•" Foreground="Gray"/>
                                        <TextBlock Text="{x:Bind Location}" Foreground="Gray"/>
                                        <TextBlock Text="•" Foreground="Gray"/>
                                        <TextBlock Text="{x:Bind DisplayTicketPrice}" Foreground="#1DB954" FontWeight="Bold"/>
                                    </StackPanel>
                                    <Button Content="Buy ticket" HorizontalAlignment="Right" Click="BuyTicket_Click" x:Name="BuyTicketButton"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>
    </Grid>
</Page>


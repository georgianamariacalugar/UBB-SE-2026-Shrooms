<Page
    x:Class="MovieMarketplace.Views.MyOrdersPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:MovieMarketplace.Models">

    <Grid Padding="40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Spacing="20" Margin="0,0,0,30">
            <Button Content="" FontFamily="Segoe MDL2 Assets" Click="Back_Click" Background="Transparent" FontSize="20"/>
            <TextBlock Text="My Purchase History" FontSize="32" FontWeight="Bold"/>
        </StackPanel>

        <ListView Grid.Row="1" x:Name="OrdersList" SelectionMode="None">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:TransactionView">
                    <Border Background="#2A2A2A" Margin="0,0,0,10" Padding="15" CornerRadius="8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Spacing="5">
                                <TextBlock Text="{x:Bind EquipmentTitle}" FontSize="20" FontWeight="Bold" Foreground="White"/>
                                <TextBlock Text="{x:Bind Amount}" Foreground="#4CAF50" FontWeight="SemiBold"/>
                                <TextBlock Text="{x:Bind ShippingAddress}" FontSize="12" Foreground="Gray"/>
                                <TextBlock Text="{x:Bind Status}" FontSize="14" FontWeight="Bold" Foreground="Orange"/>
                            </StackPanel>

                            <Button Grid.Column="1" 
                                    x:Name="ConfirmBtn"
                                    Content="Confirm Received" 
                                    VerticalAlignment="Center"
                                    Background="DarkBlue" Foreground="White"
                                    Visibility="{x:Bind IsPendingVisibility, Mode=OneWay}"
                                    Click="ConfirmDelivery_Click"
                                    Tag="{x:Bind ID}"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
<Page
    x:Class="MovieMarketplace.Views.StartPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="20">
            <TextBlock Text="Equipment Marketplace" FontSize="36" FontWeight="Bold" HorizontalAlignment="Center"/>

            <StackPanel Orientation="Horizontal" Spacing="40">
                <Button x:Name="BuyButton" 
                Content="BUY EQUIPMENT" 
                Click="BuyEquipment_Click" 
                Width="250" Height="150" 
                FontSize="20" 
                Background="DarkGreen" Foreground="White"/>

                <Button x:Name="SellButton" 
                Content="SELL EQUIPMENT" 
                Click="SellEquipment_Click" 
                Width="250" Height="150" 
                FontSize="20" 
                Background="DarkBlue" Foreground="White"/>
            </StackPanel>

            <Button x:Name="OrdersButton" 
                Content="MY ORDERS &amp; CONFIRMATIONS" 
                Click="OrdersButton_Click" 
                Width="540" Height="60" 
                FontSize="18" 
                Background="DimGray" Foreground="White"
                HorizontalAlignment="Center"
                Margin="0,10,0,0"/>

            <Button x:Name="SalesButton" 
                Content="SALES NOTIFICATIONS" 
                Click="SalesButton_Click" 
                Width="540" Height="60" 
                Background="DarkRed" Foreground="White"
                Margin="0,10,0,0"/>

            <TextBlock x:Name="LoginWarningText" 
               Text="You must be logged in to access the marketplace." 
               Foreground="Red" 
               Visibility="Collapsed" 
               HorizontalAlignment="Center"/>
        </StackPanel>
    </Grid>
</Page>
<Page
    x:Class="MovieMarketplace.Views.EquipmentDetailPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid Padding="40">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Button x:Name="BackButton" Content="" FontFamily="Segoe MDL2 Assets" FontSize="24"
                    Click="BackButton_Click" Background="Transparent" Margin="0,0,0,20" Grid.Row="0"/>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.2*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="#1A1A1A" CornerRadius="12" Margin="0,0,20,0">
                    <Image x:Name="ItemImage" Stretch="Uniform" MaxWidth="600"/>
                </Border>

                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="15" Margin="20,0,0,0">
                    <TextBlock x:Name="TitleLabel" FontSize="42" FontWeight="Bold" Foreground="White" TextWrapping="Wrap"/>
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Border Background="#333333" CornerRadius="4" Padding="10,4">
                            <TextBlock x:Name="CategoryLabel" FontSize="14" Foreground="#AAAAAA"/>
                        </Border>
                        <Border Background="#4444FF" CornerRadius="4" Padding="10,4">
                            <TextBlock x:Name="ConditionLabel" FontSize="14" Foreground="White" FontWeight="Bold"/>
                        </Border>
                    </StackPanel>
                    <TextBlock x:Name="DescriptionLabel" FontSize="20" Foreground="LightGray" FontStyle="Italic" TextWrapping="Wrap"/>
                    <TextBlock x:Name="PriceLabel" FontSize="36" Foreground="#4CAF50" FontWeight="Bold" Margin="0,15,0,0"/>

                    <Button x:Name="BuyButton" Content="Confirm Purchase" Click="BuyButton_Click"
                            Width="280" Height="70" FontSize="22" FontWeight="Bold"
                            Background="DarkGreen" Foreground="White" CornerRadius="10"/>

                    <TextBlock x:Name="ErrorText" Foreground="Red" Visibility="Collapsed" FontSize="16"/>
                </StackPanel>
            </Grid>
        </Grid>

        <Grid x:Name="ShippingModal" Background="#AA000000" Visibility="Collapsed">
            <Border Background="White" CornerRadius="15" Padding="30" Width="450" 
                    HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel Spacing="15">
                    <TextBlock Text="Shipping Details" FontSize="24" FontWeight="Bold" Foreground="Black"/>

                    <TextBox x:Name="ModalNameInput" 
                             PlaceholderText="Ex: Georgiana Popescu" 
                             Header="Full Name"
                             Foreground="Black">
                        <TextBox.HeaderTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" Foreground="Black" FontWeight="SemiBold" Margin="0,0,0,5"/>
                            </DataTemplate>
                        </TextBox.HeaderTemplate>
                    </TextBox>

                    <TextBox x:Name="ModalAddressInput" 
                             PlaceholderText="Str. Florilor nr. 5..." 
                             Header="Shipping Address"
                             Foreground="Black">
                        <TextBox.HeaderTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" Foreground="Black" FontWeight="SemiBold" Margin="0,0,0,5"/>
                            </DataTemplate>
                        </TextBox.HeaderTemplate>
                    </TextBox>

                    <TextBox x:Name="ModalPhoneInput" 
                             PlaceholderText="07xxxxxxxx" 
                             Header="Phone Number"
                             MaxLength="10"
                             Foreground="Black">
                        <TextBox.HeaderTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" Foreground="Black" FontWeight="SemiBold" Margin="0,0,0,5"/>
                            </DataTemplate>
                        </TextBox.HeaderTemplate>
                    </TextBox>

                    <TextBlock x:Name="ModalErrorText" Foreground="Red" Visibility="Collapsed" TextWrapping="Wrap" FontSize="13"/>

                    <StackPanel Orientation="Horizontal" Spacing="15" HorizontalAlignment="Right" Margin="0,10,0,0">
                        <Button Content="Cancel" Click="CancelShipping_Click" Width="100" 
                                BorderBrush="Gray" BorderThickness="1" Foreground="Black"/>

                        <Button Content="Finish Transaction" Click="ConfirmShipping_Click" 
                                Background="DarkGreen" Foreground="White" Width="180"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>
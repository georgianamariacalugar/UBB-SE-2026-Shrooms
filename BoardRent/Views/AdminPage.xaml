<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="BoardRent.Views.AdminPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:BoardRent.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Padding="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="User Administration" Style="{StaticResource TitleTextBlockStyle}" VerticalAlignment="Center" />
            <Button Grid.Column="1" Content="Sign Out" VerticalAlignment="Center" Click="OnSignOutClicked" />
        </Grid>

        <!-- Permission Guard -->
        <InfoBar Grid.Row="1" 
                 IsOpen="{x:Bind IsUnauthorized, Mode=OneWay}" 
                 Severity="Error"
                 Title="Unauthorized"
                 Message="UM-043: You do not have permission to access the User Administration page. Administrator role is required." 
                 Margin="0,0,0,20"/>

        <!-- Error Message -->
        <InfoBar Grid.Row="1"
                 IsOpen="{x:Bind IsErrorVisible, Mode=OneWay}"
                 Severity="Error"
                 Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                 Margin="0,0,0,20"/>

        <!-- Data Grid -->
        <controls:DataGrid 
            Grid.Row="2"
            ItemsSource="{x:Bind ViewModel.Users, Mode=OneWay}"
            SelectedItem="{x:Bind ViewModel.SelectedUser, Mode=TwoWay}"
            AutoGenerateColumns="False"
            Visibility="{x:Bind IsAuthorizedVisibility, Mode=OneWay}"
            x:Name="UsersDataGrid">
            <controls:DataGrid.Columns>
                <controls:DataGridTextColumn Header="Display Name" Binding="{Binding DisplayName}" />
                <controls:DataGridTextColumn Header="Username" Binding="{Binding Username}" />
                <controls:DataGridTextColumn Header="Email" Binding="{Binding Email}" />
                
                <!-- Status Badge -->
                <controls:DataGridTemplateColumn Header="Status">
                    <controls:DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border Background="{Binding IsSuspended, Converter={StaticResource StatusColorConverter}}" 
                                    CornerRadius="4" Padding="4,2" HorizontalAlignment="Left" VerticalAlignment="Center">
                                <TextBlock Text="{Binding IsSuspended, Converter={StaticResource StatusTextConverter}}" Foreground="White" FontSize="12"/>
                            </Border>
                        </DataTemplate>
                    </controls:DataGridTemplateColumn.CellTemplate>
                </controls:DataGridTemplateColumn>

            </controls:DataGrid.Columns>
        </controls:DataGrid>

        <!-- Actions Panel below grid for selected user since commands inside WinUI DataGridTemplateColumn are often challenging -->
        <StackPanel Grid.Row="2" VerticalAlignment="Bottom" HorizontalAlignment="Right" Orientation="Horizontal" Spacing="10" Margin="0,10,20,10"
                    Visibility="{x:Bind IsAuthorizedVisibility, Mode=OneWay}">
            <!-- We could map Converters, but here is a simple Actions bar per prompt -->
            <Button Content="Suspend User" Command="{x:Bind ViewModel.SuspendUserCommand}" />
            <Button Content="Unsuspend User" Command="{x:Bind ViewModel.UnsuspendUserCommand}" />
            <Button Content="Reset Pass" Command="{x:Bind ViewModel.ResetPasswordCommand}" />
            <Button Content="Unlock" Command="{x:Bind ViewModel.UnlockAccountCommand}" />
        </StackPanel>

        <!-- Pagination Footer -->
        <Grid Grid.Row="3" Margin="0,20,0,0" Visibility="{x:Bind IsAuthorizedVisibility, Mode=OneWay}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Showing users" VerticalAlignment="Center" />
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10">
                <Button Content="Prev" Command="{x:Bind ViewModel.PreviousPageCommand}" />
                <TextBlock Text="Page" VerticalAlignment="Center" />
                <TextBlock Text="{x:Bind ViewModel.CurrentPage, Mode=OneWay}" VerticalAlignment="Center" FontWeight="Bold"/>
                <TextBlock Text="of" VerticalAlignment="Center" />
                <TextBlock Text="{x:Bind ViewModel.TotalPages, Mode=OneWay}" VerticalAlignment="Center" />
                <Button Content="Next" Command="{x:Bind ViewModel.NextPageCommand}" />
            </StackPanel>
        </Grid>
    </Grid>
</Page>

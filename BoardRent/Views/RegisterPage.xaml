<Page
    x:Class="BoardRent.Views.RegisterPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid>
        <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Top" Width="400" Spacing="15" Margin="0,40,0,40">

                <TextBlock Text="Create an account" FontSize="36" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                
                <TextBlock Text="{Binding ErrorMessage}" Foreground="Red" HorizontalAlignment="Center" TextWrapping="Wrap" />

                <TextBox Header="Display Name" Text="{Binding DisplayName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <TextBox Header="Username" Text="{Binding Username, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <TextBox Header="Email" Text="{Binding Email, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                <PasswordBox Header="Password" Password="{Binding Password, Mode=TwoWay}" />
                <PasswordBox Header="Confirm Password" Password="{Binding ConfirmPassword, Mode=TwoWay}" />

                <TextBox Header="Phone Number" Text="{Binding PhoneNumber, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                <Grid ColumnSpacing="15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Header="Country" Text="{Binding Country, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Grid.Column="0" />
                    <TextBox Header="City" Text="{Binding City, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Grid.Column="1" />
                </Grid>

                <Grid ColumnSpacing="15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Header="Street Name" Text="{Binding StreetName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Grid.Column="0" />
                    <TextBox Header="Number" Text="{Binding StreetNumber, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Grid.Column="1" />
                </Grid>

                <ProgressRing IsActive="{Binding IsLoading}" HorizontalAlignment="Center" Margin="0,10,0,0" />

                <Button Content="Register" 
                        Command="{Binding RegisterCommand}" 
                        HorizontalAlignment="Stretch" 
                        Style="{StaticResource AccentButtonStyle}" 
                        Margin="0,10,0,0"/>

                <HyperlinkButton Content="Already have an account?" Command="{Binding GoToLoginCommand}" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>